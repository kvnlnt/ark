#!/bin/sh
set -e

# Run Biome check (lint + format) on staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "Running Biome check on staged files..."
echo "$STAGED_FILES" | xargs bunx --bun @biomejs/biome check --no-errors-on-unmatched || {
  echo ""
  echo "Pre-commit check failed. Fix the issues above before committing."
  exit 1
}
